# App Configuration
NEXT_PUBLIC_APP_NAME=Nexus POS
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_ENVIRONMENT=production

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Features
NEXT_PUBLIC_ENABLE_LOYALTY=true
NEXT_PUBLIC_ENABLE_SPLIT_PAYMENT=true
NEXT_PUBLIC_ENABLE_HARDWARE_BRIDGE=false
NEXT_PUBLIC_ENABLE_PWA_PROMPT=true

# Hardware Bridge (optional)
NEXT_PUBLIC_BRIDGE_URL=http://localhost:7891

# Analytics (optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false